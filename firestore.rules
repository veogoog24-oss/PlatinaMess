rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/platina_accounts/{userId} {
      // Anyone authenticated can fetch a specific profile (needed to chat and load contacts)
      allow get: if request.auth != null;

      // Users cannot query/list all accounts, preventing database scraping
      allow list: if request.auth != null && request.auth.uid == userId;

      // Only the owner can create or delete their own document
      allow create, delete: if request.auth != null && request.auth.uid == userId;

      // Anyone can update a document (to send messages), BUT they cannot modify
      // the password, email, or settings fields unless they are the owner.
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['password', 'email', 'settings']))
      );
    }
    match /artifacts/{appId}/public/data/platina_calls/{callId} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
