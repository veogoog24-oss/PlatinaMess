rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin(appId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/platina_usernames/levkkkaw) &&
        get(/databases/$(database)/documents/artifacts/$(appId)/public/data/platina_usernames/levkkkaw).data.uid == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/platina_usernames/{username} {
      // Anyone authenticated can read usernames to resolve them to UIDs
      allow read: if request.auth != null;

      // A user can claim a username if it doesn't exist, and the uid in the document matches their auth uid
      // VALIDATION: username must be alphanumeric and length >= 3
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && username.matches('^[a-zA-Z0-9_]{3,}$');

      // A user can delete/update their own username mapping
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/platina_accounts/{userId} {
      // Anyone authenticated can fetch a specific profile (needed to chat and load contacts)
      allow get: if request.auth != null;

      // Users cannot query/list all accounts, preventing database scraping
      allow list: if request.auth != null && (request.auth.uid == userId || isAdmin(appId));

      // Only the owner or an admin can create or delete documents
      allow create, delete: if request.auth != null && (request.auth.uid == userId || isAdmin(appId));

      // Anyone can update a document (to send messages), BUT they cannot modify
      // the password, email, or settings fields unless they are the owner or an admin.
      // Server side validation for schema and types
      allow update: if request.auth != null && (
        (request.auth.uid == userId || isAdmin(appId)) ||
        (
          // For other users, ONLY allow updating specific keys related to communication
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'incomingCall', 'status', 'receivedGifts'])
        )
      );
    }
    match /artifacts/{appId}/public/data/platina_calls/{callId} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
